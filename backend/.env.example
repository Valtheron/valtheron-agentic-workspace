# ===== Valtheron Backend Environment Variables =====

# Server
PORT=3001
NODE_ENV=development

# Authentication
JWT_SECRET=valtheron-dev-secret-change-in-production

# LLM Providers (optional — used by chat routes)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# CORS origins (comma-separated, defaults to localhost dev ports)
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000
