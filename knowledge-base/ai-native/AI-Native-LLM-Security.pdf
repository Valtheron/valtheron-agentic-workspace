":\"Network security\",\"UTP\":\"Networking standards and protocols\",\"UYQL\":\"Natural language and machine translation\",\"UYQN\":\"Neural networks and fuzzy systems\",\"UYQV\":\"Computer vision\"},\"series\":{\"series\":\"Series\"},\"cart\":{\"title\":\"Shopping cart\",\"empty\":\"Your cart is empty\",\"addToCart\":\"Add to cart\",\"inCart\":\"In Cart\",\"added\":\"Added!\",\"subscribe\":\"Subscribe\",\"remove\":\"Remove\",\"total\":\"Total\",\"checkout\":\"Proceed to checkout\",\"quantity\":\"Quantity\",\"item\":\"item\",\"items\":\"items\",\"institutionalAccess\":\"Institutional access\",\"individualAccess\":\"Individual access\",\"itemsInOrder\":\"{count} items in your order\",\"yourOrder\":\"Your order\",\"emptyDescription\":\"Browse our catalog and add items to your cart\",\"startShopping\":\"Start shopping\",\"continueShopping\":\"Continue shopping\",\"summary\":\"Summary\",\"product\":\"Product\",\"price\":\"Price\",\"amount\":\"Amount\",\"subtotal\":\"Subtotal:\",\"discount\":\"Discount ({code}):\",\"orderTotal\":\"Order total:\",\"vatIncluded\":\"VAT included\",\"agreeToThe\":\"I agree to the\",\"termsOfService\":\"Terms of service.\",\"purchasingOnBehalfOf\":\"Purchasing on behalf of:\",\"purchasingFor\":\"Purchasing for:\",\"selectInstitution\":\"Select institution\",\"creatingCheckout\":\"Creating checkout...\",\"errorAgreeTerms\":\"Please agree to all Terms of service to proceed.\",\"errorSelectInstitution\":\"Please select an institution before proceeding.\",\"errorCheckoutFailed\":\"Failed to initiate checkout. Please try again.\",\"errorCheckout\":\"An error occurred during checkout. Please try again.\",\"couponInfo\":\"Only one discount code can be applied at a time.\",\"success\":{\"title\":\"Payment Successful\",\"description\":\"Thank you for your purchase! Your payment has been completed.\",\"loading\":\"Processing your order...\",\"loadingDescription\":\"Please wait while we confirm your payment.\",\"invalidSession\":\"Invalid Session\",\"invalidSessionDescription\":\"This page can only be accessed after a successful payment.\",\"nextSteps\":{\"title\":\"What happens next?\",\"emailConfirmation\":{\"title\":\"Email confirmation\",\"description\":\"We'll send you an email shortly with your receipt and purchase details.\"},\"downloadAccess\":{\"title\":\"Download access\",\"description\":\"Your digital content is ready and can be downloaded anytime from your account.\"}},\"buttons\":{\"viewOrders\":\"View my orders\",\"continueShopping\":\"Continue shopping\",\"returnToCart\":\"Return to Cart\"}}},\"actions\":{\"download\":\"Download\",\"downloading\":\"Downloading\",\"preparing\":\"Preparing download\",\"downloadChapter\":\"Download chapter\",\"buyOnAmazon\":\"Buy on Amazon\",\"printAvailableAtAmazon\":\"Print: Available at Amazon\",\"buyPrint\":\"Buy print\",\"contactUs\":\"Contact us\",\"comingSoon\":\"Coming soon\",\"openAccess\":\"Open Access\",\"authorizedAccess\":\"Authorized access\",\"institutions\":\"Institutions\",\"print\":\"Print\",\"ebook\":\"E-Book\",\"chapter\":\"Chapter\"},\"cite\":{\"title\":\"Cite\",\"format\":\"Format\",\"copyToClipboard\":\"Copy to clipboard\",\"copied\":\"Copied\",\"downloadFormats\":\"Download formats\",\"risDescription\":\"ProCite RefWorks Reference Manager\",\"bibDescription\":\"BibTex Zotero\",\"endnoteDescription\":\"Endnote\"},\"about\":{\"hero\":{\"title\":\"your gateway to trusted knowledge\",\"description\":\"Reference-global.com is a comprehensive platform built for researchers, academics, professionals, and students to access resources quickly. Whether you're searching for the latest journal articles, looking for practical insights for your field, or curating materials for a library, reference-global.com brings it all together in one intuitive and easily accessible space.\"},\"features\":{\"access\":{\"title\":\"Access the content\",\"description\":\"Explore high-quality, relevant resources in one place: peer-reviewed journals, academic books from leading publishers, handbooks for practitioners, and global conference materials.\"},\"curate\":{\"title\":\"Curate and manage library resources\",\"description\":\"Discover, organize, and manage tailored materials for your institution with powerful tools that support smarter, more connected library ecosystems.\"},\"build\":{\"title\":\"Build your personal library\",\"description\":\"Create a customized space with your preferred titles, manage alerts for new content, and organize your own digital collection with ease.\"}},\"paradigm\":{\"title\":\"Brought to you by Paradigm Publishing Services\",\"description\":\"Reference-global.com is developed and managed by \u003cparadigm\u003eParadigm Publishing Services\u003c/paradigm\u003e, an innovative division of \u003cbrill\u003eDe Gruyter Brill\u003c/brill\u003e, with teams based in Boston, London, and Warsaw. Paradigm collaborates with independent publishers and scholarly presses, offering smart, flexible solutions that help partners remain globally visible, financially sustainable, and competitive in a fast-changing publishing landscape.\"},\"mission\":{\"title\":\"Shaped by a shared mission\",\"description\":\"Reference-global.com reflects Paradigm's commitment to building a more connected, accessible, and equitable future in scholarly communication. It offers a shared space for curated knowledge, bridging the gap between content creators and knowledge seekers across disciplines, industries, and borders.\"},\"cta\":{\"title\":\"Learn more about Paradigm Publishing Services\",\"button\":\"Visit Paradigm\"}},\"servicesForLibrarians\":{\"hero\":{\"title\":\"For librarians\",\"description\":\"Paradigm is transforming how academic libraries access, manage, and deliver scholarly content. By responding to the evolving needs of higher education, we offer a continuously expanding collection of high-quality publications from leading university presses and trusted academic and professional publishers.\",\"description2\":\"Our goal is to help libraries advance learning, teaching, and research by ensuring students, faculty, and scholars have reliable access to the resources they need—delivered through efficient, librarian-friendly systems.\"},\"buttons\":{\"primary\":\"View our partners\",\"secondary\":\"Partners on De Gruyter Brill\"},\"platform\":{\"title\":\"The reference-global.com platform\",\"description\":\"Developed with the needs of librarians at its core, reference-global.com combines robust functionality with intuitive design—empowering institutions to manage collections efficiently, integrate seamlessly with existing systems, and maximise discoverability.\"},\"features\":{\"management\":{\"title\":\"Effortless resource management\",\"description\":\"Our centralised librarian portal simplifies the oversight of subscriptions, licensing, and access permissions. With a comprehensive dashboard of usage statistics, libraries can streamline operations, reduce administrative burden, and optimise collection development.\"},\"metadata\":{\"title\":\"Enriched metadata for discoverability\",\"description\":\"We provide high-quality metadata, including MARC, ONIX, and KBART files, at no additional cost. This enables improved catalogue integration and ensures consistent, accurate discoverability across major discovery platforms.\"},\"integration\":{\"title\":\"Flexible integration\",\"description\":\"Reference-global.com supports a variety of acquisition models and works seamlessly with institutional systems—from authentication protocols to link resolvers—ensuring smooth implementation across library environments.\"},\"drm\":{\"title\":\"DRM-free, user-centered access\",\"description\":\"All subscription content is DRM-free, allowing users to download, print, and save materials for personal use—supporting both academic freedom and convenience.\"},\"discovery\":{\"title\":\"Discovery service compatibility\",\"description\":\"Reference-global.com is fully compatible with leading discovery and indexing platforms, helping users quickly locate and access content anytime, anywhere.\"}},\"guidance\":{\"text\":\"For guidance on using the librarian portal and downloading MARC and KBART files, visit the \u003clink\u003einstructions page\u003c/link\u003e.\"},\"cta\":{\"title\":\"Explore how we help libraries to better serve their communities\",\"button\":\"Visit Paradigm\"}},\"librarianManual\":{\"hero\":{\"title\":\"Librarian manual\",\"description\":\"Complete guide for librarians using the reference-global platform. This manual provides detailed instructions, best practices, and troubleshooting information to help you maximize your use of our services.\"},\"buttons\":{\"download\":\"Download manual (PDF)\",\"contactSupport\":\"Contact support\",\"viewFaq\":\"View FAQ\"},\"preview\":{\"title\":\"Manual preview\"}},\"servicesForPublishers\":{\"hero\":{\"title\":\"For publishers\",\"description\":\"At Paradigm, we deliver a comprehensive suite of services designed to empower academic publishers and editorial teams. Our support spans advanced technology, operational infrastructure, and strategic guidance, tailored to enhance every stage of the publishing process. All editorial authority, including decisions related to content creation, selection, and ownership, remains fully in the hands of our partners. Paradigm serves as a trusted ally, empowering our partners' work by providing the tools and expertise needed to navigate scholarly publishing with confidence and efficiency.\"},\"solutions\":{\"title\":\"Our solutions\",\"description\":\"Paradigm's services are modular, adaptable, and complementary, enabling each publishing partner to select the tailored support their publications require. Our services can be used together or selectively, ranging from content distribution to full-scale editorial production and visibility-enhancing marketing strategies.\",\"description2\":\"We support a full spectrum of publishing models, including diamond and gold open access with APC-based systems, subscription management, and Subscribe to Open initiatives. Publishers select the model or combination of services that align with their mission and financial strategy, while we deliver the infrastructure and expert support, ensuring effective implementation.\"},\"sections\":{\"technology\":{\"title\":\"Technology and production\",\"features\":{\"platform\":{\"title\":\"Content platform\",\"description\":\"We operate a proprietary content publishing and distribution platform that supports DOI registration, automated metadata creation, citation linking, and advanced search capabilities. Our technology is fully integrated with international scholarly infrastructure, including Crossref, indexing databases, and the ORCID system, and is built to meet the highest accessibility standards.\",\"description2\":\"For publishers seeking greater autonomy and control, we provide the option to design and implement a fully secure, independent content platform based on Open Journal Systems (OJS), customized to their specific editorial and operational needs.\"},\"editorial\":{\"title\":\"Editorial systems\",\"description\":\"Besides publishing technology, we offer a range of editorial software tailored by our specialists to fit each title's unique workflow. These include submission platforms, APC collection tools, plagiarism detection software, and research integrity solutions. For publishing partners that prefer OJS-based technology, we offer integrated submission and peer review solutions. Our team implements these systems while advising on process design and best practices to ensure seamless, efficient management.\"},\"services\":{\"title\":\"Editorial services\",\"description\":\"Editorial support encompasses language editing, copy-editing, and typesetting. These services guarantee readability, a professional presentation of content, and compliance with the academic publishing standards of published papers. In addition, we offer XML metadata and full-text formatting options that enhance visibility and compliance with indexing databases.\"}}},\"visibility\":{\"title\":\"Visibility and recognition\",\"features\":{\"indexing\":{\"title\":\"Indexing support\",\"description\":\"Comprehensive indexing assistance, including strategic guidance, is one of our greatest strengths and is a key service in our portfolio, consistently recognised and valued by our partners. We go beyond what a typical service provider offers. We do not just send metadata but also support editors in navigating complex submission and assessment processes, evaluating the readiness of their titles, guiding them through the requirements of various services, applying on their behalf, and ultimately delivering the content.\",\"description2\":\"Our indexing support is adaptable and customised to each title's requirements and scope, from basic metadata delivery to comprehensive evaluations, strategic consulting, and active involvement in the formal application process on behalf of the publisher.\",\"description3\":\"While we provide strategic guidance and technical support, all decisions regarding the implementation of indexing strategies remain entirely at the discretion of the publishers. We do not restrict independent applications submitted directly by our partners, should they choose to pursue that route.\",\"description4\":\"We are proud to support over 180 journals with CiteScore and more than 120 journals with an Impact Factor. The number of Paradigm-partnered journals indexed in Journal Citation Reports has more than tripled in recent years, reflecting the success of our collaborative approach.\"},\"marketing\":{\"title\":\"Marketing solutions\",\"description\":\"Our marketing services focus on visibility and academic impact. Our partners benefit from targeted email campaigns, outreach with custom-designed promotional materials, and social media engagement, increasing awareness, readership, and citations.\"},\"consulting\":{\"title\":\"Consulting services\",\"description\":\"Our experienced publishing advisors provide customised consulting to support publications at each stage of their development. These services include advice on editorial strategy, improving submission and peer review workflows, managing peer reviewers, and employing data-driven methods to enhance visibility and citation performance.\"}}},\"ownership\":{\"title\":\"Ownership and editorial independence\",\"features\":{\"rights\":{\"title\":\"Publisher rights\",\"description\":\"Titles we host, distribute, and provide services for remain the property of their publishers. This ownership is clearly reflected on each website, whether on reference-global.com or individual platforms built with the use of OJS software, where the publisher's logo and copyright statements are prominently displayed. Paradigm enters into formal service-level agreements that define roles and responsibilities, ensure licensing for content distribution, and protect the publisher's branding and intellectual property.\"},\"decisions\":{\"title\":\"Decision-making\",\"description\":\"Paradigm does not engage in editorial or policy decisions. Our role is to provide tools, guidance, and expert support, while full authority remains with the publishers and editorial boards. We serve as partners in the process - supportive, but never directive.\"},\"management\":{\"title\":\"Website content management\",\"description\":\"Publishing partners retain full control over how information related to their titles - such as aims and scope, editorial policies, submission guidelines, and contact details - is presented on the reference-global.com platform and individual OJS platforms. While Paradigm provides the technical infrastructure and offers expert advice, the decisions remain with the editorial teams. We periodically conduct site reviews to share best practices and updated requirements from indexing services, while fully respecting our partners' editorial independence.\"}}},\"support\":{\"title\":\"Day-to-day support\",\"description\":\"Each publication is assigned a dedicated customer service expert who provides consistent, hands-on support across all aspects of daily operations. From assistance with technical issues to advice on best practices, our specialists ensure that editorial teams receive prompt, practical support. They also act as the primary contact point between the editorial boards and our internal teams, promoting smooth communication and ensuring efficient service delivery.\"}},\"cta\":{\"title\":\"Ready to publish? Find the services and support you need\",\"button\":\"Contact us\"}},\"partner\":{\"title\":\"Interested in publishing with Paradigm?\",\"description\":\"Paradigm is your trusted partner in publishing and distributing books, journals, and proceedings. Join leading publishers.\",\"button\":\"Become a partner\"},\"share\":{\"title\":\"Share\",\"facebook\":\"Facebook\",\"x\":\"X (prev. Twitter)\",\"linkedin\":\"LinkedIn\",\"bluesky\":\"Bluesky\",\"email\":\"Email\",\"copyLink\":\"Copy link\",\"copied\":\"Copied!\",\"shareVia\":\"Share via\"},\"publishingEthics\":{\"hero\":{\"title\":\"Publishing ethics\",\"description\":\"At Paradigm, we are committed to promoting responsible and transparent scholarly communication. We support publishers, authors, and editorial teams in upholding the highest standards of integrity across the research ecosystem. To foster fairness and accountability, we provide guidance aligned with industry best practices, offer strategic advice based on the evolving expectations of indexing services and the academic community, and regularly review platform settings on reference-global.com. Our approach is informed by internationally recognized frameworks, including the principles set forth by the Committee on Publication Ethics (COPE).\"},\"sections\":{\"whatWeOffer\":{\"title\":\"What we offer\",\"description\":\"Paradigm demonstrates its dedication to ethical publishing through comprehensive support across three main areas:\",\"features\":{\"guidance\":{\"title\":\"Guidance resources for journal editors\",\"description\":\"We maintain a dedicated and regularly updated collection of advisory materials covering topics such as authorship, peer review, corrections, and retractions. These resources are openly accessible through our platform and reflect the latest best practices in scholarly publishing.\"},\"tools\":{\"title\":\"Tools and infrastructure\",\"description\":\"Our modular services are designed to support ethical workflows at every stage of the publishing process—from initial submission to final publication. We provide a suite of adaptable tools, including submission management systems, plagiarism detection software, and research integrity solutions.\"},\"advisory\":{\"title\":\"Advisory support\",\"description\":\"For complex ethical questions, our experienced publishing specialists offer tailored guidance. While we do not mediate disputes or override editorial decisions, we help our partners navigate challenging situations by referencing international standards, identifying applicable policies, and suggesting clear, practical next steps. Our role is to build confidence and clarity—without compromising editorial autonomy.\"}}},\"editorialIndependence\":{\"title\":\"Editorial independence\",\"description\":\"Paradigm fully respects the autonomy of our publishing partners. All decisions related to content, editorial policy, and peer review rest solely with the publishers we support.\",\"description2\":\"We do not interfere in editorial matters or influence outcomes. Instead, we act as a collaborative partner—providing the tools, infrastructure, and expert support needed to uphold transparency, integrity, and independent decision-making across the publishing lifecycle.\"},\"sharedResponsibility\":{\"title\":\"Shared responsibility\",\"description\":\"In keeping with our values, Paradigm may suspend or discontinue collaboration if serious ethical breaches occur. This is not a punitive action, but a necessary measure to preserve mutual trust among authors, readers, and publishers and to safeguard the credibility of the scholarly record.\",\"description2\":\"We remain dedicated to fostering publishing environments where integrity, openness, and independence are not only safeguarded but also flourish.\"}}},\"register\":{\"messages\":{\"userAlreadyExists\":\"A user with the email address {email} has already registered an account. Please go to the log-in page. If you have forgotten your password, or have not yet created a password, you can use the 'Reset Password' link in the user menu.\",\"titleAccountCreated\":\"Thank you for registering on reference\u0026#8209;global.com\",\"accountCreated\":\"\u003cp\u003eAn activation email has been sent to {email}.\u003c/p\u003e\u003cp\u003ePlease follow the instructions in the message to activate your account and set your password.\u003c/p\u003e\",\"checkSpam\":\"If you don’t see the email in your inbox, please check your spam or junk folder.\",\"checkEmail\":\"Check your email\"}},\"contact\":{\"title\":\"Looking for answers?\",\"subtitle\":\"Still need assistance? We're happy to help - simply use one of the contact forms below.\",\"faqSubtitle\":\"Consult our FAQ page for quick help with common questions.\",\"faqButton\":\"View FAQ\",\"info\":{\"offices\":{\"boston\":{\"town\":\"Boston\",\"name\":\"Paradigm Publishing Services\\nDe Gruyter Brill, Inc.\",\"address\":\"121 High Street, 3rd Fl.\\nBoston, MA 02110\\nUnited States\",\"phone\":\"+1 857 214 2298\"},\"london\":{\"town\":\"London\",\"name\":\"Paradigm Publishing Services\\nUbiquity Press Ltd.\",\"address\":\"Unit 3N, 6 Osborn Street\\nLondon, E1 6TD\\nUnited Kingdom\",\"phone\":\"+44 (0) 207 323 0343\"},\"warsaw\":{\"town\":\"Warsaw\",\"name\":\"Paradigm Publishing Services\\nDe Gruyter Brill Sp. z o.o.\",\"address\":\"Nowogrodzka 4/3\\n00-513 Warsaw\",\"phone\":\"+48 22 245 33 55\"}},\"email\":\"contact@pps.pub\",\"facebookURL\":\"https://www.facebook.com/sciendoglobal/\",\"linkedInURL\":\"https://www.linkedin.com/company/sciendo-publishing-services/\",\"blueSkyURL\":\"https://bsky.app/profile/reference-global.bsky.social\"},\"forms\":{\"labels\":{\"name\":\"Name and surname\",\"email\":\"Email\",\"country\":\"Country\",\"publicationType\":\"Publication type\",\"publicationTitle\":\"Publication title (journal / book / proceedings)\",\"publicationUrl\":\"Publication URL\",\"comments\":\"Comments\",\"inquiry\":\"Inquiry\",\"institution\":\"Institution\",\"phone\":\"Phone number\",\"send\":\"Send\",\"clear\":\"Clear\",\"successMessageTitle\":\"Message sent successfully\",\"successMessageBody\":\"Thank you for contacting us.\u003cbr/\u003eWe’ve received your message and will get back to you shortly.\",\"errorMessageTitle\":\"Error sending message\",\"errorMessageBody\":\"Please contact us directly at \u003cemailUrl\u003e{email}\u003c/emailUrl\u003e - our team will be happy to assist you.\"},\"fieldOptions\":{\"publicationTypes\":{\"journal\":\"Journal\",\"conference\":\"Conference Proceedings\",\"book\":\"Book\",\"other\":\"Other\"},\"inquiry\":{\"journal\":\"Journal services\",\"book\":\"Book services\",\"conference\":\"Conference services\",\"whiteLabel\":\"White Label Publishing House\",\"other\":\"Other inquiries\"}},\"authors\":{\"title\":\"I am an author\",\"subtitle\":\"I would like to enquire about my manuscript\"},\"editors\":{\"title\":\"I am an editor\",\"subtitle\":\"I would like to publish a journal or conference proceedings\"},\"librarians\":{\"title\":\"I am a librarian\",\"subtitle\":\"I am seeking information about content access for my library\"},\"inquiry\":{\"title\":\"General inquiry\",\"subtitle\":\"I have a different question or would like to reach support\"}}},\"librarian\":{\"root\":{\"urlKey\":\"librarian\",\"label\":\"Librarian\"},\"tabs\":{\"holdings\":{\"urlKey\":\"holdings\",\"label\":\"Holdings\"},\"usage\":{\"urlKey\":\"usage\",\"label\":\"Usage\"},\"update-ips\":{\"urlKey\":\"update-ips\",\"label\":\"Update IPs\",\"title\":\"Self-service editing and updating of your IP addresses\",\"body\":\"\u003cp\u003eWe partner with \u003cb\u003eThe IP Registry\u003c/b\u003e to simplify the process of checking, updating, and managing IP addresses used to authenticate access to content—making it easier for librarians to ensure seamless access.\u003c/p\u003e\u003cp\u003eThe IP Registry is a centralized, trusted database of more than 1.5 billion verified IP addresses from over 60,000 content licensing organizations worldwide. It is maintained for the benefit of the global scholarly communication community and is accessible to both publishers and libraries.\u003c/p\u003e\u003cp\u003eWith the IP Registry, a service by PSI, publishers and libraries can save time, reduce administrative workload, minimize errors, improve the accuracy of usage metrics, and ensure that the right users have access to the right content.\u003c/p\u003e\",\"sidebarBody\":\"\u003cIf\u003eTo update or manage your IP addresses, please log in using the link below. If you don’t have an account, you can register directly on the login page.\u003c/p\u003e\",\"buttonText\":\"Login to PSI\",\"buttonURL\":\"https://www.psiregistry.org/\"}},\"labels\":{\"contentLicencedBy\":\"Content licenced by:\",\"viewUsageFor\":\"View usage for:\",\"noEntitlements\":\"Currently there are no {type} licenced by {institution}\",\"noAccess\":\"\u003cp\u003eYou do not have access to the selected account, or the link you followed is no longer valid.\u003c/p\u003e\u003cp\u003ePlease double-check the link, return to the homepage, or log in again.\u003c/p\u003e\u003cp\u003eIf you believe this is an error, feel free to contact our support team for assistance.\u003c/p\u003e\"},\"institutionSelector\":{\"invalid\":\"Invalid account\",\"emptyList\":\"No available accounts\"},\"downloadButton\":{\"exportAll\":\"Export all holdings\",\"export\":\"Export\",\"exportAs\":\"Download as {extension}\"},\"tables\":{\"journalsWithCount\":\"\u003ctype\u003eJournals\u003c/type\u003e ({count} {count, plural, =0 {titles} =1 {title} other {titles}})\",\"booksWithCount\":\"\u003ctype\u003eBooks\u003c/type\u003e ({count} {count, plural, =0 {titles} =1 {title} other {titles}})\",\"packagesWithCount\":\"\u003ctype\u003ePackages\u003c/type\u003e ({count} {count, plural, =0 {items} =1 {item} other {items}})\",\"title\":\"Title\",\"productId\":\"Product ID\",\"accessPeriod\":\"Access period\",\"coveragePeriod\":\"Coverage period\",\"from\":\"From:\",\"to\":\"To:\",\"noExpiry\":\"No expiry\"}},\"userPages\":{\"title\":\"Welcome back, {name}\",\"welcomeMessage\":\"\u003cb\u003eWelcome back, {name}\u003c/b\u003eNice to see you again!\"},\"notifications\":{\"types\":{\"NewIssueInJournal\":{\"title\":\"New issue available\",\"text\":\"A new issue \u003cissueUrl\u003e{issueTitle}\u003c/issueUrl\u003e of \u003cjournalUrl\u003e{journalTitle}\u003c/journalUrl\u003e has been published.\"},\"NewArticleInAop\":{\"title\":\"New article in Ahead of Print publication\",\"text\":\"A new Ahead of Print article, \u003carticleUrl\u003e{articleTitle}\u003c/articleUrl\u003e, has been published in \u003cjournalUrl\u003e{journalTitle}\u003c/journalUrl\u003e.\"},\"NewArticle\":{\"title\":\"New article published\",\"text\":\"A new article, \u003carticleUrl\u003e{articleTitle}\u003c/articleUrl\u003e, has been published in \u003cjournalUrl\u003e{journalTitle}\u003c/journalUrl\u003e.\"},\"NewBookInSeries\":{\"title\":\"New title in your followed series\",\"text\":\"A new book, \u003cbookUrl\u003e{bookTitle}\u003c/bookUrl\u003e, has been added to the \u003cseriesUrl\u003e{seriesTitle}\u003c/seriesUrl\u003e series.\"},\"BookNowAvailable\":{\"title\":\"New book is now available\",\"text\":\"The book, \u003cbookUrl\u003e{bookTitle}\u003c/bookUrl\u003e, has been released.\"}},\"title\":\"Notifications\",\"productsTitle\":\"Publications you’re following\",\"enableProductButton\":\"Turn on notifications\",\"disableProductButton\":\"Turn off notifications\",\"removeProductButton\":\"Remove from list\",\"deleteProductConfirmation\":\"Are you sure you want to remove notifications for \u003cb\u003e{productName}\u003c/b\u003e?\u003cbr\u003e\u003c/br\u003eYou can add it back at any time from the product page.\",\"noUserMessage\":\"You need to be logged in to turn on notifications.\",\"noIndividualMessage\":\"You need to have a personal account to turn on notifications.\",\"tooltips\":{\"add\":{\"journal\":\"Follow this journal for updates\",\"article\":\"Follow this article for updates\",\"book\":\"Follow this book for updates\",\"chapter\":\"Follow this chapter for updates\",\"series\":\"Follow this series for updates\",\"issue\":\"Follow this issue for updates\",\"conference\":\"Follow these proceedings for updates\"},\"remove\":{\"journal\":\"Unfollow this journal\",\"article\":\"Unfollow this article\",\"book\":\"Unfollow this book\",\"chapter\":\"Unfollow this chapter\",\"series\":\"Unfollow this series\",\"issue\":\"Unfollow this issue\",\"conference\":\"Unfollow these proceedings\"}}},\"favourites\":{\"title\":\"Favourite titles\",\"listSelectLabel\":\"Favourites list\",\"createListLabel\":\"Create new list\",\"createListWindowTitle\":\"Create new list\",\"createListWindowText\":\"Create a new favourites list:\",\"createListWindowButton\":\"Create\",\"semanticSearchFieldLabel\":\"AI-powered search\",\"searchFieldPlaceholder\":\"Search in this list...\",\"renameListLabel\":\"Rename this list\",\"renameListWindowTitle\":\"Rename list\",\"renameListWindowText\":\"Rename \u003cb\u003e{listName}\u003c/b\u003e list to:\",\"renameListWindowButton\":\"Rename\",\"moveListWindowTitle\":\"Move product\",\"moveListWindowText\":\"Move \u003cb\u003e{productName}\u003c/b\u003e to the list selected bellow:\",\"moveListWindowButton\":\"Move\",\"makeDefaultListLabel\":\"Make this list default\",\"deleteListLabel\":\"Delete this list\",\"deleteListConfirmation\":\"Are you sure you want to delete \u003cb\u003e{listName}\u003c/b\u003e list?\u003cbr\u003e\u003c/br\u003eAll favourite items in this list will also be removed.\",\"moveProductButton\":\"Move to...\",\"removeProductButton\":\"Remove from list\",\"deleteProductConfirmation\":\"Are you sure you want to remove \u003cb\u003e{productName}\u003c/b\u003e from \u003cb\u003e{listName}\u003c/b\u003e list?\u003cbr\u003e\u003c/br\u003eYou can add it back at any time from the product page.\",\"noUserMessage\":\"You need to be logged in to mark items as favourites.\",\"noIndividualMessage\":\"You need to have a personal account to mark items as favourites.\",\"tooltips\":{\"journal\":\"Add this journal to favourites\",\"article\":\"Add this article to favourites\",\"book\":\"Add this book to favourites\",\"chapter\":\"Add this chapter to favourites\",\"series\":\"Add this series to favourites\",\"issue\":\"Add this issue to favourites\",\"conference\":\"Add these proceedings to favourites\"}},\"accountSettings\":{\"title\":\"Account settings\",\"subtitle\":\"Manage your account settings\",\"email\":{\"title\":\"Email\",\"subtitle\":\"Manage your email settings\"},\"setPassword\":{\"title\":\"Set New Password\",\"label\":\"New Password\",\"placeholder\":\"Enter your new password\",\"button\":\"Set Password\",\"buttonLoading\":\"Setting Password...\",\"errorRequired\":\"Please enter a new password\",\"errorMinLength\":\"New password must be at least 8 characters long\",\"errorGeneric\":\"Failed to change password. Please try again.\"}},\"faq\":{\"title\":\"FAQs – Frequently Asked Questions\",\"breadcrumb\":\"FAQ\",\"categories\":{\"editors\":\"Editors\",\"authors\":\"Authors\",\"librarians\":\"Librarians\",\"libraryUsers\":\"Library users\"},\"callToAction\":{\"title\":\"Need more help?\",\"description\":\"Didn't find the answer here? Reach out through our contact forms — we're here to help.\",\"buttonText\":\"Visit contact page\"}},\"metrics\":{\"impactFactor\":\"Impact Factor\",\"fiveYearImpactFactor\":\"5-Year Impact Factor\",\"jci\":\"Journal Citation Indicator\",\"citeScore\":\"CiteScore\",\"sjr\":\"SCImago Journal Rank\",\"snip\":\"Source Normalized Impact per Paper\",\"mein\":\"MEIN Index\",\"gsh5index\":\"Google Scholar h5-index\",\"gsh5median\":\"Google Scholar h5-median\",\"icv\":\"Index Copernicus Value\",\"downloads_chart_title\":\"Downloads (last {count} months)\"},\"login\":{\"methods\":{\"individual\":{\"title\":\"Individual access\",\"description\":\"Login using your email address and password.\",\"button\":\"Log in as individual user\"},\"institutional\":{\"title\":\"Institutional access\",\"description\":\"Access through your university, library\u2028or organization.\",\"button\":\"Log in via institution\"},\"librarian\":{\"title\":\"Librarian access\",\"description\":\"Access library management tools\u2028and order history.\",\"button\":\"Log in as librarian\"}},\"register\":{\"noAccountTitle\":\"Don't have an account?\",\"noAccountDescription\":\"You can create a new account by clicking the button below.\",\"button\":\"Register for free\"},\"popup\":{\"title\":{\"individual\":\"Log in as an individual user\",\"librarian\":\"Log in as a librarian\"},\"button\":\"Log in\",\"forgotPassword\":\"Forgot your password? Click here to reset it\"}},\"resetPassword\":{\"title\":\"Reset password or login\",\"emailLabel\":\"Email address\",\"emailPlaceholder\":\"Enter your email address\",\"resetButton\":\"Reset password\",\"resetButtonLoading\":\"Sending reset email...\",\"passwordlessButton\":\"Passwordless login\",\"passwordlessButtonLoading\":\"Sending login email...\",\"errorRequired\":\"Please enter an email address\",\"errorInvalidEmail\":\"Please enter a valid email address\",\"errorGeneric\":\"Failed to send email. Please try again.\",\"errorNetwork\":\"Network error. Please check your connection and try again.\",\"successResetPassword\":\"Reset password email sent successfully\",\"successPasswordlessLogin\":\"Passwordless login email sent successfully\",\"checkEmail\":\"Check your email\"},\"metadata\":{\"search\":{\"title\":\"Search | Paradigm Publishing Services\",\"description\":\"Search for books, journals, and conference proceedings. Reference-global.com - your gateway to trusted scholarly knowledge.\"},\"cart\":{\"title\":\"Shopping cart | Paradigm Publishing Services\",\"description\":\"Review your shopping cart and proceed to checkout. Reference-global.com - your gateway to trusted scholarly knowledge.\"},\"home\":{\"title\":\"Paradigm Publishing Services | Books, Journals \u0026 Research\",\"description\":\"Search, discover, and access academic books, journals, and conference proceedings. Reference-global.com - your gateway to trusted scholarly knowledge.\"},\"about\":{\"title\":\"About Us | Paradigm Publishing Services\",\"description\":\"Reference-global.com is your gateway to trusted knowledge. Discover our comprehensive platform for researchers, academics, professionals, and students.\"},\"contact\":{\"title\":\"Contact Us | Paradigm Publishing Services\",\"description\":\"Get in touch with Paradigm Publishing Services. Find contact information for our offices in Boston, London, and Warsaw.\"},\"faq\":{\"title\":\"Frequently Asked Questions | Paradigm\",\"description\":\"Find answers to common questions about Paradigm Publishing Services, content access, subscriptions, and more.\"},\"partners\":{\"title\":\"Our Partners | Paradigm Publishing Services\",\"description\":\"Discover our network of academic and professional publishing partners. Join leading publishers in scholarly communication.\"},\"subjects\":{\"title\":\"Browse by Subject | Paradigm\",\"description\":\"Explore academic content across all subject areas. Find books, journals, and articles in your field of interest.\"},\"publishingEthics\":{\"title\":\"Publishing Ethics | Paradigm Publishing Services\",\"description\":\"Our commitment to ethical publishing practices. Learn about our standards for integrity, transparency, and responsible scholarly communicati